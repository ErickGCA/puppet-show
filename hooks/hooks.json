{
  "description": "puppet-show hooks — capture Task dispatches/returns and enforce per-puppet contract scope/tools at runtime.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/puppet-capture.js\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit|Grep|Glob|Bash|WebFetch|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/puppet-runtime.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/puppet-capture.js\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
